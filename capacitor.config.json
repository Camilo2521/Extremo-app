{
  "appId": "com.extremo.tracker",
  "appName": "Extremo",
  "webDir": "www",
  "android": {
    "backgroundColor": "#1A1A18",
    "webContentsDebuggingEnabled": false
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 1500,
      "launchAutoHide": true,
      "backgroundColor": "#1A1A18",
      "showSpinner": false
    },
    "StatusBar": {
      "style": "Dark",
      "backgroundColor": "#1A1A18"
    }
  }
}
